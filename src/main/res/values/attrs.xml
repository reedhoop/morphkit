<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ═══════════════════════════════════════════════════════════════════════
         MorphKit 主题属性 — 控件默认样式入口
         宿主 Theme 通过这些 reference 属性，将控件外观指向不同的 Style 皮肤
         ═══════════════════════════════════════════════════════════════════════ -->

    <attr name="morphButtonStyle" format="reference" />
    <attr name="morphTextViewStyle" format="reference" />
    <attr name="morphEditTextStyle" format="reference" />
    <attr name="morphCardStyle" format="reference" />
    <attr name="morphRadioButtonStyle" format="reference" />
    <attr name="morphCheckBoxStyle" format="reference" />

    <!-- ═══════════════════════════════════════════════════════════════════════
         交互模式 — iOS 按压变色 vs Material 涟漪水波纹
         ═══════════════════════════════════════════════════════════════════════ -->

    <attr name="morphInteractionMode" format="enum">
        <!-- iOS 风格：按压整体变色，无涟漪 -->
        <enum name="ios" value="0" />
        <!-- Material 风格：保留系统 Ripple 涟漪水波纹 -->
        <enum name="material" value="1" />
    </attr>

    <!-- ═══════════════════════════════════════════════════════════════════════
         控件样式枚举 — 可通过 XML 声明
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- MorphButton 样式：FILLED(0) 填充按钮 / PLAIN(1) 透明按钮 -->
    <attr name="morphButtonVariant" format="enum">
        <enum name="filled" value="0" />
        <enum name="plain" value="1" />
    </attr>

    <!-- MorphEditText 样式：SEARCH(0) 搜索栏 / BARE(1) 裸输入 -->
    <attr name="morphEditTextVariant" format="enum">
        <enum name="search" value="0" />
        <enum name="bare" value="1" />
    </attr>

    <!-- ═══════════════════════════════════════════════════════════════════════
         MorphButton 自定义属性
         ═══════════════════════════════════════════════════════════════════════ -->

    <declare-styleable name="MorphButton">
        <!-- 按钮圆角半径 -->
        <attr name="morphCornerRadius" format="dimension" />
        <!-- 交互模式 -->
        <attr name="morphInteractionMode" />
        <!-- 按钮样式变体 -->
        <attr name="morphButtonVariant" />
    </declare-styleable>

    <!-- ═══════════════════════════════════════════════════════════════════════
         MorphTextView 自定义属性
         ═══════════════════════════════════════════════════════════════════════ -->

    <declare-styleable name="MorphTextView">
        <attr name="morphInteractionMode" />
    </declare-styleable>

    <!-- ═══════════════════════════════════════════════════════════════════════
         MorphEditText 自定义属性
         ═══════════════════════════════════════════════════════════════════════ -->

    <declare-styleable name="MorphEditText">
        <attr name="morphCornerRadius" />
        <attr name="morphInteractionMode" />
        <!-- 输入框样式变体 -->
        <attr name="morphEditTextVariant" />
    </declare-styleable>

    <!-- ═══════════════════════════════════════════════════════════════════════
         MorphCardView 自定义属性
         ═══════════════════════════════════════════════════════════════════════ -->

    <declare-styleable name="MorphCardView">
        <attr name="morphCornerRadius" />
        <attr name="morphInteractionMode" />
        <!-- 是否启用毛玻璃模式（背景模糊） -->
        <attr name="isGlassmorphism" format="boolean" />
        <!-- 毛玻璃模糊半径（px），推荐范围 15–35 -->
        <attr name="glassmorphismBlurRadius" format="float" />
    </declare-styleable>

    <!-- ═══════════════════════════════════════════════════════════════════════
         MorphRadioButton 自定义属性
         ═══════════════════════════════════════════════════════════════════════ -->

    <declare-styleable name="MorphRadioButton">
        <attr name="morphInteractionMode" />
    </declare-styleable>

    <!-- ═══════════════════════════════════════════════════════════════════════
         MorphCheckBox 自定义属性
         ═══════════════════════════════════════════════════════════════════════ -->

    <declare-styleable name="MorphCheckBox">
        <attr name="morphInteractionMode" />
    </declare-styleable>

</resources>
